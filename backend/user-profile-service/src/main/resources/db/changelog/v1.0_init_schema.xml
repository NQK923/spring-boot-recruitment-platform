<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-profile-tables" author="gemini">
        <createTable tableName="profiles">
            <column name="user_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="phone_number" type="VARCHAR(50)"/>
            <column name="summary" type="TEXT"/>
        </createTable>

        <createTable tableName="experiences">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="profile_user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_exp_profile" references="profiles(user_id)"/>
            </column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="company_name" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
        </createTable>

         <createTable tableName="cvs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="profile_user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_cv_profile" references="profiles(user_id)"/>
            </column>
            <column name="file_id" type="UUID"/>
            <column name="version_name" type="VARCHAR(255)"/>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
