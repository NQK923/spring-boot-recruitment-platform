    <changeSet id="4-seed-companies-and-company-users" author="codex">
        <insert tableName="companies">
            <column name="name" value="Acme Corporation"/>
            <column name="description" value="Enterprise HR platform provider with distributed teams across APAC."/>
            <column name="website" value="https://www.acme-corp.example"/>
            <column name="logo_url" value="https://cdn.example.com/logos/acme.png"/>
        </insert>

        <insert tableName="companies">
            <column name="name" value="Globex Corporation"/>
            <column name="description" value="Global manufacturing and R&amp;D firm expanding into Southeast Asia."/>
            <column name="website" value="https://www.globex.example"/>
            <column name="logo_url" value="https://cdn.example.com/logos/globex.png"/>
        </insert>

        <insert tableName="company_users">
            <column name="company_id" valueComputed="(SELECT id FROM companies WHERE name='Acme Corporation')"/>
            <column name="user_id" valueNumeric="2"/>
            <column name="role" value="COMPANY_ADMIN"/>
        </insert>

        <insert tableName="company_users">
            <column name="company_id" valueComputed="(SELECT id FROM companies WHERE name='Acme Corporation')"/>
            <column name="user_id" valueNumeric="4"/>
            <column name="role" value="RECRUITER"/>
        </insert>

        <insert tableName="company_users">
            <column name="company_id" valueComputed="(SELECT id FROM companies WHERE name='Globex Corporation')"/>
            <column name="user_id" valueNumeric="3"/>
            <column name="role" value="COMPANY_ADMIN"/>
        </insert>

        <insert tableName="company_users">
            <column name="company_id" valueComputed="(SELECT id FROM companies WHERE name='Globex Corporation')"/>
            <column name="user_id" valueNumeric="5"/>
            <column name="role" value="RECRUITER"/>
        </insert>

        <sql>
            SELECT setval('companies_id_seq', (SELECT MAX(id) FROM companies));
        </sql>
    </changeSet>


    <changeSet id="5-backfill-company-metadata" author="codex">
        <update tableName="companies">
            <column name="company_size" value="500 - 1000 employees"/>
            <column name="company_address" value="Saigon Innovation Hub, District 3, Ho Chi Minh City"/>
            <where>name = 'Acme Corporation'</where>
        </update>

        <update tableName="companies">
            <column name="company_size" value="800 - 1200 employees"/>
            <column name="company_address" value="Hoa Khanh Industrial Park, Da Nang City"/>
            <where>name = 'Globex Corporation'</where>
        </update>
    </changeSet>



