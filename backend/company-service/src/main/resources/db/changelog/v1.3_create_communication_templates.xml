<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.3-1-create-communication-templates" author="codex">
        <createTable tableName="communication_templates">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_communication_templates"/>
            </column>
            <column name="company_id" type="BIGINT"/>
            <column name="name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="subject" type="VARCHAR(255)"/>
            <column name="body" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="shared_with_recruiters" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_user_id" type="BIGINT"/>
            <column name="updated_by_user_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="communication_templates" indexName="idx_comm_templates_company_id">
            <column name="company_id"/>
        </createIndex>

        <createIndex tableName="communication_templates" indexName="idx_comm_templates_category">
            <column name="category"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
