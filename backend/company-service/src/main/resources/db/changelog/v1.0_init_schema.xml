<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="1-create-companies-table" author="nqk923">
        <createTable tableName="companies">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="website" type="VARCHAR(255)"/>
            <column name="logo_url" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="2-create-company-users-table" author="nqk923">
        <createTable tableName="company_users">
            <column name="company_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <addForeignKeyConstraint baseTableName="company_users" baseColumnNames="company_id" constraintName="fk_company_users_company" referencedTableName="companies" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="v1.3-1-create-communication-templates" author="codex">
        <createTable tableName="communication_templates">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_communication_templates"/>
            </column>
            <column name="company_id" type="BIGINT"/>
            <column name="name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="subject" type="VARCHAR(255)"/>
            <column name="body" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="shared_with_recruiters" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_user_id" type="BIGINT"/>
            <column name="updated_by_user_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="communication_templates" indexName="idx_comm_templates_company_id">
            <column name="company_id"/>
        </createIndex>

        <createIndex tableName="communication_templates" indexName="idx_comm_templates_category">
            <column name="category"/>
        </createIndex>
    </changeSet>

    <changeSet id="5-add-company-metadata" author="codex">
        <addColumn tableName="companies">
            <column name="company_size" type="VARCHAR(255)"/>
            <column name="company_address" type="VARCHAR(500)"/>
        </addColumn>

    </changeSet>
</databaseChangeLog>
