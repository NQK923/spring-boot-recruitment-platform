<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="4-add-created-by-to-invitations" author="nqk923">
        <addColumn tableName="invitations">
            <column name="created_by_user_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="5-seed-super-admin-user" author="nqk923">
        <insert tableName="users">
            <column name="email" value="superadmin@recruitment.local"/>
            <column name="password_hash" value="$2b$12$3Kl7KntW8A8FEDANx9psGOqiln4BL.1VmjVjFPNW0jB1ZXpRRwtDW"/>
            <column name="email_verified_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert tableName="user_roles">
            <column name="user_id" valueComputed="(SELECT id FROM users WHERE email='superadmin@recruitment.local')"/>
            <column name="role_id" valueComputed="(SELECT id FROM roles WHERE name='SUPER_ADMIN')"/>
        </insert>

        <sql>
            SELECT setval('users_id_seq', (SELECT MAX(id) FROM users));
        </sql>
    </changeSet>

</databaseChangeLog>
