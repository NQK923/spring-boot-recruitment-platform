<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-job-tables" author="nqk923">
        <createTable tableName="job_positions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="department" type="VARCHAR(255)"/>
            <column name="level" type="VARCHAR(100)"/>
        </createTable>

        <createTable tableName="job_postings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="job_position_id" type="BIGINT"/>
            <column name="title" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="requirements" type="TEXT"/>
            <column name="location" type="VARCHAR(255)"/>
            <column name="work_type" type="VARCHAR(100)"/>
            <column name="status" type="VARCHAR(50)" defaultValue="DRAFT"/>
            <column name="recruiter_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="job_postings" baseColumnNames="job_position_id" constraintName="fk_posting_position" referencedTableName="job_positions" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
