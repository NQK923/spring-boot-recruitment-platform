<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-interview-tables" author="gemini">
        <createTable tableName="interviews">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="application_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="scheduled_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="timezone" type="VARCHAR(100)"/>
            <column name="format" type="VARCHAR(50)"/>
            <column name="location_or_link" type="VARCHAR(255)"/>
            <column name="outcome" type="VARCHAR(50)"/>
        </createTable>

        <createTable tableName="interview_participants">
            <column name="interview_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false" foreignKeyName="fk_participant_interview" references="interviews(id)"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)"/> <!-- CANDIDATE or INTERVIEWER -->
        </createTable>

        <createTable tableName="interview_feedback">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="interview_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_feedback_interview" references="interviews(id)"/>
            </column>
            <column name="interviewer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="score" type="INT"/>
            <column name="comments" type="TEXT"/>
            <column name="outcome" type="VARCHAR(50)"/> <!-- PASS, FAIL, HOLD -->
        </createTable>
    </changeSet>

</databaseChangeLog>
