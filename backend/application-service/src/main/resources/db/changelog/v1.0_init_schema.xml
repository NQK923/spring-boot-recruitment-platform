<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-application-tables" author="nqk923">
        <createTable schemaName="application_service" tableName="applications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="job_posting_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="candidate_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="cv_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)"/>
            <column name="applied_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable schemaName="application_service" tableName="application_history">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="application_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_history_application"
                             references="application_service.applications(id)"/>
            </column>
            <column name="from_status" type="VARCHAR(50)"/>
            <column name="to_status" type="VARCHAR(50)"/>
            <column name="changed_by_user_id" type="BIGINT"/>
            <column name="note" type="TEXT"/>
            <column name="timestamp" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
