<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.5-1-create-application-interviews" author="codex">
        <createTable tableName="application_interviews">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_application_interviews" nullable="false"/>
            </column>
            <column name="application_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="scheduled_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="timezone" type="VARCHAR(80)"/>
            <column name="location" type="VARCHAR(255)"/>
            <column name="instructions" type="TEXT"/>
            <column name="created_by_user_id" type="BIGINT"/>
            <column name="updated_by_user_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="application_interviews"
                                 baseColumnNames="application_id"
                                 constraintName="fk_application_interviews_application"
                                 referencedTableName="applications"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createIndex tableName="application_interviews" indexName="idx_application_interviews_application_id">
            <column name="application_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="v1.5-2-create-application-offers" author="codex">
        <createTable tableName="application_offers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_application_offers" nullable="false"/>
            </column>
            <column name="application_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="salary_amount" type="DECIMAL(18,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(12)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="status" type="VARCHAR(32)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="responded_at" type="TIMESTAMP"/>
            <column name="responded_by_candidate_id" type="BIGINT"/>
            <column name="decision_note" type="TEXT"/>
            <column name="created_by_user_id" type="BIGINT"/>
            <column name="updated_by_user_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="application_offers"
                                 baseColumnNames="application_id"
                                 constraintName="fk_application_offers_application"
                                 referencedTableName="applications"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createIndex tableName="application_offers" indexName="idx_application_offers_application_id">
            <column name="application_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
