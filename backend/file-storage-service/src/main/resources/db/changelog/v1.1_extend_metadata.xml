<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20241104-extend-file-metadata" author="codex">
        <addColumn tableName="file_metadata">
            <column name="storage_bucket" type="VARCHAR(255)"/>
        </addColumn>
        <addColumn tableName="file_metadata">
            <column name="public_file" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="file_metadata">
            <column name="public_url" type="VARCHAR(1024)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
